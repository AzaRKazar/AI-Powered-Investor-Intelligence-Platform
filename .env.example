# Postgres connection (local dev via docker-compose.yml, or Azure Postgres Flexible Server)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=investor_admin
POSTGRES_PASSWORD=devpassword
POSTGRES_DATABASE=investor_intelligence
# Azure Postgres requires SSL; local Docker Postgres has no SSL listener, so disable it locally.
POSTGRES_SSLMODE=disable

# Azure OpenAI (leave as placeholders until the resource is provisioned)
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-key
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_DEPLOYMENT=your-chat-deployment-name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your-embedding-deployment-name

# Azure AI Search (leave as placeholders until the resource is provisioned)
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your-search-key
AZURE_SEARCH_INDEX_NAME=investor-intelligence
